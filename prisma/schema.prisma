generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum KelasLevel {
  DASAR
  MENENGAH
  LANJUTAN
}

enum SumberDokumen {
  LINK
  UPLOAD
}

enum MateriTipe {
  TEKS
  VIDEO
}

enum VideoProvider {
  YOUTUBE
  VIMEO
}

enum UserRole {
  USER
  PREMIUM
  ADMIN
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  password      String
  nama          String
  role          UserRole         @default(USER)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  quizAttempts  QuizAttempt[]
  tugasSubmissions TugasSubmission[]
}

model Materi {
  id            String           @id @default(cuid())
  judul         String
  slug          String           @unique
  pdfUrl        String?
  videoUrl      String?
  videoProvider VideoProvider?
  tipe          MateriTipe       @default(TEKS)
  kelas         KelasLevel       @default(DASAR)
  isPremium     Boolean          @default(false)
  urutan        Int              @default(0)
  published     Boolean          @default(true)
  sumberDokumen SumberDokumen?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([isPremium, published])
  @@index([kelas])
}

model Quiz {
  id          String        @id @default(cuid())
  judul       String
  deskripsi   String        @db.Text
  kelas       KelasLevel    @default(DASAR)
  isPremium   Boolean       @default(false)
  published   Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  questions   QuizQuestion[]
  attempts    QuizAttempt[]

  @@index([isPremium, published])
  @@index([kelas])
}

model QuizQuestion {
  id          String       @id @default(cuid())
  quizId      String
  pertanyaan  String       @db.Text
  urutan      Int          @default(0)
  quiz        Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options     QuizOption[]

  @@index([quizId])
  @@index([urutan])
}

model QuizOption {
  id          String       @id @default(cuid())
  questionId  String
  teks        String       @db.Text
  isCorrect   Boolean      @default(false)
  question    QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model QuizAttempt {
  id          String    @id @default(cuid())
  userId      String
  quizId      String
  score       Int
  jawaban     Json
  completedAt DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId, quizId])
  @@index([quizId])
}

model Article {
  id               String           @id @default(cuid())
  judul            String
  slug             String           @unique
  isi              String           @db.Text
  ringkasan        String           @db.Text
  coverUrl         String?
  thumbnailUrl     String?
  kategori         String?
  metaTitle        String?
  metaDescription  String?
  ogImageUrl       String?
  published        Boolean          @default(false)
  publishedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Package {
  id            String           @id @default(cuid())
  nama          String
  deskripsi     String           @db.Text
  harga         Decimal          @db.Decimal(12, 2)
  durasiBulan   Int
  fiturList     String[]
  isPopuler     Boolean          @default(false)
  isActive      Boolean          @default(true)
  published     Boolean          @default(true)
  urutan        Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Tugas {
  id               String       @id @default(cuid())
  judul            String
  slug             String       @unique
  instruksi        String       @db.Text
  fileInstruksiUrl String?
  kelas            KelasLevel   @default(DASAR)
  isPremium        Boolean      @default(false)
  deadline         DateTime?
  urutan           Int          @default(0)
  published        Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  submissions      TugasSubmission[]

  @@index([isPremium, published])
  @@index([kelas])
}

model TugasSubmission {
  id          String                 @id @default(cuid())
  tugasId     String
  userId      String
  submittedAt DateTime               @default(now())
  tugas       Tugas                  @relation(fields: [tugasId], references: [id], onDelete: Cascade)
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  files       TugasSubmissionFile[]

  @@unique([tugasId, userId])
  @@index([tugasId])
  @@index([userId])
}

model TugasSubmissionFile {
  id            String           @id @default(cuid())
  submissionId  String
  fileUrl       String
  fileName      String
  fileSizeBytes Int
  submission    TugasSubmission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model ContactMessage {
  id            String           @id @default(cuid())
  nama          String
  email         String
  pesan         String           @db.Text
  isRead        Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}
